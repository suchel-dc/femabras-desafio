# --- Dependencies ---
**/node_modules/
/frontend/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js & Build Output ---
**/.next/
**/out/
**/build/
**/.turbo/
.cache/

# --- Environment & Security ---
**/.env*
!**/.env.example
**/.vercel
*.pem
# Ignore local workspace settings that might contain paths
.vscode/

# --- Testing & Debug Logs ---
**/coverage/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# --- System & TypeScript ---
**/*.tsbuildinfo
**/next-env.d.ts
**/.DS_Store
**/*.db
Thumbs.db

# --- Go Backend ---
**/tmp/
**/bin/
# This catches all compiled binaries in the backend folder
backend/main
backend/server
backend/*.exe
backend/*.out
vendor/
# If you use 'air' for live reloading
.air.toml